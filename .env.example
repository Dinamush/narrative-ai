# ── LLM (optional — falls back to heuristic extraction if unavailable) ──

# Provider: ollama | openai | none
# Default: ollama when no OpenAI key is set
LLM_PROVIDER=ollama

# Shared model override (used by both providers)
# LLM_MODEL=llama3.2

# ── Ollama (local, free) ──
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Smarter local model (9B reasoning, ~5.6 GB Q4_K_M):
# ollama pull hf.co/empero-ai/Qwythos-9B-Claude-Mythos-5-1M-GGUF:Q4_K_M
# OLLAMA_MODEL=qwythos:9b-q4

# ── OpenAI (cloud) ──
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o-mini

# ── Debugging ──
# LLM_DEBUG=1

# ── E2E tests ──
# E2E_BASE_URL=http://localhost:3001
